// ======================= HELPERS =======================
function bracketHost(ip) {
  return (ip.indexOf(":") !== -1 && ip.indexOf(".") === -1)
    ? "[" + ip + "]" : ip;
}
function hostInList(h, list) {
  h = (h || "").toLowerCase();
  for (var i = 0; i < list.length; i++) {
    var d = list[i].toLowerCase();
    if (h === d || h.indexOf("." + d) !== -1
        || shExpMatch(h, "*." + d) || dnsDomainIs(h, d)) return true;
  }
  return false;
}
function hasKeyword(s) {
  s = (s || "").toLowerCase();
  for (var i = 0; i < KEYWORDS.length; i++) {
    if (s.indexOf(KEYWORDS[i]) !== -1) return true;
  }
  return false;
}
function isIranTLD(h) {
  h = (h || "").toLowerCase();
  return h === "ir" || h.slice(-3) === ".ir" || h.indexOf(".ir.") !== -1;
}
function isJoIPv4(host) {
  for (var i = 0; i < JO_IPV4.length; i++) {
    if (isInNet(host, JO_IPV4[i][0], JO_IPV4[i][1])) return true;
  }
  return false;
}
function isJoIPv6(host) {
  var h = (host || "").toLowerCase().replace(/^\[/, "").replace(/\]$/, "");
  if (h.indexOf(":") === -1) return false;
  for (var i = 0; i < JO_IPV6.length; i++) {
    if (h.indexOf(JO_IPV6[i].toLowerCase()) === 0) return true;
  }
  return false;
}
function isIPAddress(host) {
  return /^[\d.]+$/.test(host) || /^[\[0-9a-fA-F:]+\]?$/.test(host);
}

// ===================== BUILD PROXY =====================
function buildChain(portSet) {
  if (!ENABLE_SOCKS && !ENABLE_HTTP) return "PROXY 127.0.0.1:9";
  var h = bracketHost(PROXY_IP), toks = [];
  if (ENABLE_SOCKS) {
    var sp = portSet.socks || [];
    for (var s = 0; s < sp.length; s++) toks.push("SOCKS5 " + h + ":" + sp[s]);
  }
  if (ENABLE_HTTP) {
    var hp = portSet.http || [];
    for (var p = 0; p < hp.length; p++) toks.push("PROXY " + h + ":" + hp[p]);
  }
  return toks.length === 0 ? "PROXY 127.0.0.1:9" : toks.join("; ");
}

// مسارات جاهزة
function lobbyChain() { return buildChain(PORTS.lobby);  }
function matchChain()  { return buildChain(PORTS.match);  }
function cdnChain()    { return buildChain(PORTS.cdn);    }
function voiceChain()  { return buildChain(PORTS.voice);  }
function fullChain()   { return buildChain({
  socks: PORTS.lobby.socks.concat(PORTS.match.socks).concat(PORTS.cdn.socks).concat(PORTS.voice.socks),
  http:  PORTS.lobby.http.concat(PORTS.match.http)
}); }

// ======================= MAIN ==========================
function FindProxyForURL(url, host) {
  host = host || url;

  // 1. حظر إيران
  if (BLOCK_IR && isIranTLD(host)) return "PROXY 127.0.0.1:9";

  // 2. دومينات الصوت
  if (hostInList(host, VOICE_DOMAINS)) return voiceChain();

  // 3. دومينات CDN والتحديثات
  if (hostInList(host, CDN_DOMAINS)) return cdnChain();

  // 4. دومينات اللوبي (API / Auth / Matchmaking / Store)
  if (hostInList(host, LOBBY_DOMAINS) || hostInList(host, LOCAL_DOMAINS))
    return lobbyChain();

  // 5. دومينات المباريات الحية (كل المودات)
  if (hostInList(host, MATCH_DOMAINS)) return matchChain();

  // 6. عنوان IP أردني مباشر:
  //    – إذا كان غير موجود في نطاقات اللعبة سابقاً → مسار المباريات
  if (isIPAddress(host) && (isJoIPv4(host) || isJoIPv6(host)))
    return matchChain();

  // 7. أي دومين يحمل كلمة مفتاحية → مسار كامل
  if (hasKeyword(host) || hasKeyword(url)) return fullChain();

  // 8. FORCE_ALL – كل حركة PUBG تمر عبر اللوبي كـ fallback
  return lobbyChain();
}
